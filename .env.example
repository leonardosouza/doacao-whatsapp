# App
APP_NAME=DoaZap
APP_ENV=development
DEBUG=False
API_KEY=your-api-key-here

# OpenAI
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.3

# Z-API
ZAPI_INSTANCE_ID=your-instance-id
ZAPI_TOKEN=your-token
ZAPI_CLIENT_TOKEN=your-client-token

# Conversation
CONVERSATION_HISTORY_LIMIT=10

# Database
DATABASE_URL=postgresql://doacao_user:doacao_pass@db:5432/doacao_db

# PostgreSQL (usado pelo docker-compose)
POSTGRES_USER=doacao_user
POSTGRES_PASSWORD=doacao_pass
POSTGRES_DB=doacao_db

# Render (para deploy forçado via API)
RENDER_API_KEY=your-render-api-key
RENDER_SERVICE_ID=srv-your-service-id

# New Relic APM
NEW_RELIC_LICENSE_KEY=your-license-key-here
NEW_RELIC_APP_NAME=DoaZap
NEW_RELIC_LOG=stdout
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
